{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AgroMitra (Frontend & Backend)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Backend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/src/server.js",
      "runtimeArgs": ["--env-file=.env"],
      "console": "integratedTerminal"
    }
  ]
}
